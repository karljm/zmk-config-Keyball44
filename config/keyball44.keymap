#define DEFAULT 0
#define NUM     1
#define SYM     2
#define FUN     3
#define EDIT    4
#define MOUSE   5
#define SNIPE   6
#define SCROLL  7
#define HSCROLL 8
#define SETTING 9
#define SWITCH  10
#define OPTIONS 11

#include <behaviors/mouse_keys.dtsi>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/mouse.h>
#include <dt-bindings/zmk/ext_power.h>
#include "behaviors.dtsi"
#include "combos.dtsi"

&lt {
    tapping-term-ms = <240>;
    flavor = "balanced";
    quick-tap-ms = <150>;
};

&mt {
    tapping-term-ms = <200>;
    flavor = "tap-preferred";
    quick-tap-ms = <150>;
};

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            label = "QWRT";
            bindings = <
            &lt OPTIONS ESCAPE &kp B     &kp L         &kp D        &kp W      &kp Z                 &none            &kp F  &kp O      &kp U    &kp J      &lt OPTIONS BACKSPACE
            &lt NUM FSLH   &kp N     &kp R         &kp T        &kp S      &kp G                 &kp Y            &kp H  &kp A      &kp E    &kp I      &lt NUM SQT
            &sw_ctl_next    &kp Q     &kp X         &kp M        &kp C      &kp V                 &kp K            &kp P  &kp DOT    &kp COMMA &kp SEMI   &kp RIGHT_SHIFT
            &kp LGUI        &sw_gui_next  &mo MOUSE  &edit_lt EDIT SPACE  &mo SCROLL            &mo SYM    &edit_hold_cleanup                                    &to MOUSE
            >;
        };

        number_layer {
            label = "NUM";
            bindings = <
            &trans  &none         &kp NUMBER_9  &kp NUMBER_8  &kp NUMBER_7  &none                &none          &kp NUMBER_7  &kp NUMBER_8  &kp NUMBER_9  &none         &trans
            &trans  &none  &kp NUMBER_3  &kp NUMBER_2  &kp NUMBER_1  &kp NUMBER_0                &kp NUMBER_0   &kp NUMBER_1  &kp NUMBER_2  &kp NUMBER_3  &none         &trans
            &none   &none         &kp NUMBER_6  &kp NUMBER_5  &kp NUMBER_4  &none                &none          &kp NUMBER_4  &kp NUMBER_5  &kp NUMBER_6  &none         &none
            &trans  &trans        &trans        &trans        &trans                              &trans         &trans                                                  &trans
            >;
        };

        symbol_layer {
            label = "SYM";
            bindings = <
            &kp GRAVE  &kp PIPE   &kp AMPS  &kp QMARK  &kp EXCL   &kp AT                    &kp CARET  &kp HASH   &kp ASTRK  &kp DLLR   &kp BSLH   &none
            &kp TILDE  &kp DQT    &kp LBRC  &kp LPAR   &kp RPAR   &kp RBRC                  &kp UNDER  &kp EQUAL  &kp PLUS   &kp MINUS  &kp PRCNT  &none
            &none      &kp SQT    &kp LT    &kp LBKT   &kp RBKT   &kp GT                    &kp COLON  &kp SEMI   &kp FSLH   &kp COMMA  &kp DOT    &none
            &trans     &trans     &trans    &trans     &trans                               &trans     &trans                                     &trans
            >;
        };

        function_layer {
            label = "FUN";
            bindings = <
            &none   &kp F1  &kp F2   &kp F3   &kp F4   &none                                 &none   &none  &none  &none  &none  &none
            &none   &kp F5  &kp F6   &kp F7   &kp F8   &none                                 &none   &none  &none  &none  &none  &none
            &none   &kp F9  &kp F10  &kp F11  &kp F12  &none                                 &none   &none  &none  &none  &none  &none
            &trans  &trans  &trans   &trans   &trans                                         &trans  &mo 3                       &trans
            >;
        };

        edit_layer {
            label = "EDIT";
            bindings = <
            &none  &none  &none      &none  &none  &none                              &none  &none         &none      &none  &none  &none
            &none  &sk LSHIFT  &kp ESCAPE  &none  &kp ENTER  &none                           &none  &kp BACKSPACE  &kp DELETE  &none &sk LSHIFT  &none
            &none  &none  &none      &tog_on SCROLL     &tog_on MOUSE     &none       &none  &none         &none      &none  &none  &none
            &none  &none  &none      &none  &none                                      &none  &none                                  &none
            >;
        };

        mouse_layer {
            label = "MOUSE";
            bindings = <
            &none   &none           &scroll_horizontal  &scroll_vertical  &none      &none        &none   &none      &scroll_vertical  &scroll_horizontal     &none           &none
            &none   &tog_on SNIPE   &mkp MCLK        &mkp RCLK       &mkp LCLK  &none        &none   &mkp LCLK  &mkp RCLK       &mkp MCLK           &tog_on SNIPE   &none
            &none   &none           &mouse_to_default &mkp MB5       &mkp MB4   &none        &none   &mkp MB4   &mkp MB5        &mouse_to_default   &none           &none
            &trans  &trans          &trans          &trans        &trans                       &trans         &trans                                      &to MOUSE
            >;
        };

        snipe_layer {
            label = "SNIPE";
            bindings = <
            &none   &none           &scroll_horizontal  &scroll_vertical  &none      &none        &none   &none      &scroll_vertical  &scroll_horizontal     &none           &none
            &none   &tog_off SNIPE  &mkp MCLK        &mkp RCLK       &mkp LCLK  &none        &none   &mkp LCLK  &mkp RCLK       &mkp MCLK           &tog_off SNIPE  &none
            &none   &none           &mouse_to_default &mkp MB5       &mkp MB4   &none        &none   &mkp MB4   &mkp MB5        &mouse_to_default   &none           &none
            &trans  &trans  &trans  &trans  &trans                                          &trans  &trans                          &trans
            >;
        };

        scroll_layer {
            label = "SCROLL";
            bindings = <
            &none   &none           &scroll_horizontal  &scroll_vertical  &none      &none        &none   &none      &scroll_vertical  &scroll_horizontal     &none           &none
            &none   &tog_on SNIPE   &mkp MCLK        &mkp RCLK       &mkp LCLK  &none        &none   &mkp LCLK  &mkp RCLK       &mkp MCLK           &tog_on SNIPE   &none
            &none   &none           &mouse_to_default &mkp MB5       &mkp MB4   &none        &none   &mkp MB4   &mkp MB5        &mouse_to_default   &none           &none
            &trans  &trans  &trans  &trans  &trans                                          &trans  &trans                          &trans
            >;
        };

        horizontal_scroll_layer {
            label = "HSCROLL";
            bindings = <
            &none   &none           &scroll_horizontal  &scroll_vertical  &none      &none        &none   &none      &scroll_vertical  &scroll_horizontal     &none           &none
            &none   &tog_on SNIPE   &mkp MCLK        &mkp RCLK       &mkp LCLK  &none        &none   &mkp LCLK  &mkp RCLK       &mkp MCLK           &tog_on SNIPE   &none
            &none   &none           &mouse_to_default &mkp MB5       &mkp MB4   &none        &none   &mkp MB4   &mkp MB5        &mouse_to_default   &none           &none
            &trans  &trans  &trans  &trans  &trans                                          &trans  &trans                          &trans
            >;
        };

        setting_layer {
            label = "SETTING";
            bindings = <
            &trans  &trans      &trans        &trans        &trans        &trans            &trans  &trans  &trans  &trans  &trans  &trans
            &trans  &bt BT_CLR  &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &trans            &trans  &trans  &trans  &trans  &trans  &trans
            &trans  &trans      &trans        &trans        &trans        &trans            &trans  &trans  &trans  &trans  &trans  &trans
            &trans  &trans      &trans        &trans        &trans                          &trans  &trans                          &trans
            >;
        };

        switch_layer {
            label = "SWITCH";
            bindings = <
            &none  &none  &none        &none    &none  &none                            &none  &none  &none  &none  &none  &none
            &none  &none  &kp ESCAPE    &kp LS(TAB)  &kp TAB    &none                       &none  &none  &none  &none  &none  &none
            &none  &none  &none        &none    &none  &none                            &none  &none  &none  &none  &none  &none
            &none  &none  &none        &kp ESCAPE    &none                                  &none  &none                          &none
            >;
        };

        options_layer {
            label = "OPTIONS";
            bindings = <
            &none       &none        &none        &none        &none        &bootloader      &bootloader  &none  &none  &none  &none  &none
            &sys_reset        &bt BT_CLR  &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &none      &none  &none  &none  &none  &none  &sys_reset
            &ext_power EP_OFF &none  &none      &none        &none        &none          &none  &none  &none  &none  &none  &ext_power EP_ON
            &none             &none  &none      &none        &none                       &none  &none                          &none
            >;
        };
    };
};

/ {
    combos {
        compatible = "zmk,combos";
        combo_to_base {
            timeout-ms = <50>;
            key-positions = <19 20 21>;
            bindings = <&to 0>;
        };

        combo_esc {
            timeout-ms = <25>;
            key-positions = <19 20>;
            bindings = <&kp ESCAPE>;
        };

        // LETTERS
        combo_z {
            timeout-ms = <25>;
            key-positions = <3 4>;
            bindings = <&kp Z>;
        };

        // MODIFIERS
        combo_lgui {
            timeout-ms = <50>;
            key-positions = <39 14>;
            bindings = <&skq LGUI>;
            slow-release;
        };

        combo_lsft {
            timeout-ms = <50>;
            key-positions = <39 16>;
            bindings = <&skq LEFT_SHIFT>;
            slow-release;
        };

        combo_lctl {
            timeout-ms = <50>;
            key-positions = <39 13>;
            bindings = <&skq LCTRL>;
            slow-release;
        };

        combo_lalt {
            timeout-ms = <50>;
            key-positions = <39 15>;
            bindings = <&skq LALT>;
            slow-release;
        };

        combo_lboot {
            timeout-ms = <500>;
            key-positions = <26 27 28 29 40>;
            bindings = <&bootloader>;
        };

        combo_rboot {
            timeout-ms = <500>;
            key-positions = <30 31 32 33 41>;
            bindings = <&bootloader>;
        };

        combo_rgui {
            timeout-ms = <50>;
            key-positions = <42 21>;
            bindings = <&skq RGUI>;
            slow-release;
        };

        combo_rsft {
            timeout-ms = <50>;
            key-positions = <42 19>;
            bindings = <&skq RIGHT_SHIFT>;
            slow-release;
        };

        combo_rctl {
            timeout-ms = <50>;
            key-positions = <42 22>;
            bindings = <&skq RCTRL>;
            slow-release;
        };

        combo_ralt {
            timeout-ms = <50>;
            key-positions = <42 20>;
            bindings = <&skq RALT>;
            slow-release;
        };

        // LAYERS
        combo_setting {
            timeout-ms = <50>;
            key-positions = <42 43>;
            bindings = <&mo SETTING>;
        };

        combo_mouse {
            timeout-ms = <50>;
            key-positions = <38 28>;
            bindings = <&mo MOUSE>;
            slow-release;
        };

        combo_scroll {
            timeout-ms = <50>;
            key-positions = <38 27>;
            bindings = <&mo SCROLL>;
            slow-release;
        };

        combo_hscroll {
            timeout-ms = <50>;
            key-positions = <38 26>;
            bindings = <&mo HSCROLL>;
            slow-release;
        };

        combo_snipe {
            timeout-ms = <50>;
            key-positions = <38 37>;
            bindings = <&mo SNIPE>;
            slow-release;
        };

        // SWITCHING
        combo_gui_next {
            timeout-ms = <50>;
            key-positions = <14 16 39>;
            bindings = <&sw_gui_next>;
            slow-release;
        };

        combo_ctl_next {
            timeout-ms = <50>;
            key-positions = <13 16 39>;
            bindings = <&sw_ctl_next>;
            slow-release;
        };

        combo_alt_next {
            timeout-ms = <50>;
            key-positions = <26 28 39>;
            bindings = <&sw_alt_next>;
            slow-release;
        };

        combo_alt_next_both {
            timeout-ms = <20>;
            key-positions = <20 16>;
            bindings = <&sw_alt_next>;
            slow-release;
        };

        combo_alt_prev_both {
            timeout-ms = <20>;
            key-positions = <20 15>;
            bindings = <&sw_alt_prev>;
            slow-release;
        };
        
        combo_ctl_next_both {
            timeout-ms = <20>;
            key-positions = <19 16>;
            bindings = <&sw_ctl_next>;
            slow-release;
        };
        
        combo_ctl_prev_both {
            timeout-ms = <20>;
            key-positions = <19 15>;
            bindings = <&sw_ctl_prev>;
            slow-release;
        };


        combo_gui_next_both {
            timeout-ms = <20>;
            key-positions = <21 16>;
            bindings = <&sw_gui_next>;
            slow-release;
        };


        combo_gui_prev_both {
            timeout-ms = <20>;
            key-positions = <21 15>;
            bindings = <&sw_gui_prev>;
            slow-release;
        };






        // SYMBOLS
        // NON-THUMB

        combo_lbkt {
            timeout-ms = <30>;
            key-positions = <7 9>;
            bindings = <&kp LBKT>;
        };
        combo_rbkt {
            timeout-ms = <30>;
            key-positions = <7 10>;
            bindings = <&kp RBKT>;
        };

        combo_lpar {
            timeout-ms = <30>;
            key-positions = <19 21>;
            bindings = <&kp LPAR>;
        };
        combo_rpar {
            timeout-ms = <30>;
            key-positions = <19 22>;
            bindings = <&kp RPAR>;
        };
        
        combo_lbrc {
            timeout-ms = <30>;
            key-positions = <31 33>;
            bindings = <&kp LBRC>;
        };
        combo_rbrc {
            timeout-ms = <30>;
            key-positions = <31 34>;
            bindings = <&kp RBRC>;
        };

        combo_plus {
            timeout-ms = <30>;
            key-positions = <27 28>;
            bindings = <&kp PLUS>;
        };

        combo_minus {
            timeout-ms = <30>;
            key-positions = <26 27>;
            bindings = <&kp MINUS>;
        };

        combo_astrk {
            timeout-ms = <30>;
            key-positions = <25 28>;
            bindings = <&kp ASTRK>;
        };
        
        combo_percent {
            timeout-ms = <25>;
            key-positions = <26 28>;
            bindings = <&kp PRCNT>;
        };

        combo_equal {
            timeout-ms = <30>;
            key-positions = <31 32>;
            bindings = <&kp EQUAL>;
        };

        combo_under {
            timeout-ms = <30>;
            key-positions = <32 33>;
            bindings = <&kp UNDER>;
        };

        combo_sqt {
            timeout-ms = <30>;
            key-positions = <20 21>;
            bindings = <&kp SQT>;
        };

        combo_dqt {
            timeout-ms = <30>;
            key-positions = <8 9>;
            bindings = <&kp DQT>;
        };

        // THUMB

        // LEFT
        
        combo_hash {
            timeout-ms = <30>;
            key-positions = <39 2>;
            bindings = <&kp HASH>;
        };
        
        combo_tilde {
            timeout-ms = <30>;
            key-positions = <39 3>;
            bindings = <&kp TILDE>;
        };

        combo_grave {
            timeout-ms = <30>;
            key-positions = <39 9>;
            bindings = <&kp GRAVE>;
        };

        combo_backslash {
            timeout-ms = <30>;
            key-positions = <39 25>;
            bindings = <&kp BSLH>;
        };

        combo_less_than {
            timeout-ms = <30>;
            key-positions = <39 27>;
            bindings = <&kp LT>;
        };

        combo_greater_than {
            timeout-ms = <30>;
            key-positions = <39 28>;
            bindings = <&kp GT>;
        };

        // RIGHT

        combo_pipe {
            timeout-ms = <30>;
            key-positions = <42 7>;
            bindings = <&kp PIPE>;
        };

        combo_ampersand {
            timeout-ms = <30>;
            key-positions = <42 8>;
            bindings = <&kp AMPS>;
        };

        combo_caret {
            timeout-ms = <30>;
            key-positions = <42 31>;
            bindings = <&kp CARET>;
        };

        combo_dollar {
            timeout-ms = <30>;
            key-positions = <42 32>;
            bindings = <&kp DLLR>;
        };
        
        combo_colon {
            timeout-ms = <30>;
            key-positions = <42 33>;
            bindings = <&kp COLON>;
        };

        combo_at {
            timeout-ms = <30>;
            key-positions = <42 34>;
            bindings = <&kp AT>;
        };

    };
};

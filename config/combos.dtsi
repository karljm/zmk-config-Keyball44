/ {
    combos {
        compatible = "zmk,combos";
        combo_esc {
            timeout-ms = <50>;
            key-positions = <19 20 21>;
            bindings = <&to 0>;
        };

        combo_lgui {
            timeout-ms = <50>;
            key-positions = <39 14>;
            bindings = <&skq LGUI>;
            slow-release;
        };

        combo_lsft {
            timeout-ms = <50>;
            key-positions = <39 16>;
            bindings = <&skq LEFT_SHIFT>;
            slow-release;
        };

        combo_lctl {
            timeout-ms = <50>;
            key-positions = <39 13>;
            bindings = <&skq LCTRL>;
            slow-release;
        };

        combo_lalt {
            timeout-ms = <50>;
            key-positions = <39 15>;
            bindings = <&skq LALT>;
            slow-release;
        };

        combo_lboot {
            timeout-ms = <500>;
            key-positions = <26 27 28 29 40>;
            bindings = <&bootloader>;
        };

        combo_rboot {
            timeout-ms = <500>;
            key-positions = <30 31 32 33 41>;
            bindings = <&bootloader>;
        };

        combo_setting {
            timeout-ms = <50>;
            key-positions = <42 43>;
            bindings = <&mo SETTING>;
        };

        combo_rgui {
            timeout-ms = <50>;
            key-positions = <42 21>;
            bindings = <&skq RGUI>;
            slow-release;
        };

        combo_rsft {
            timeout-ms = <50>;
            key-positions = <42 19>;
            bindings = <&skq RIGHT_SHIFT>;
            slow-release;
        };

        combo_rctl {
            timeout-ms = <50>;
            key-positions = <42 22>;
            bindings = <&skq RCTRL>;
            slow-release;
        };

        combo_ent {
            timeout-ms = <50>;
            key-positions = <14 16>;
            bindings = <&kp ENTER>;
        };

        combo_ralt {
            timeout-ms = <50>;
            key-positions = <42 20>;
            bindings = <&skq RALT>;
            slow-release;
        };

        combo_mouse {
            timeout-ms = <50>;
            key-positions = <39 28>;
            bindings = <&mo MOUSE>;
            slow-release;
        };

        combo_scroll {
            timeout-ms = <50>;
            key-positions = <39 27>;
            bindings = <&mo SCROLL>;
            slow-release;
        };

        combo_gui_next {
            timeout-ms = <50>;
            key-positions = <39 13 16>;
            bindings = <&sw_gui_next>;
            slow-release;
        };

        combo_gui_prev {
            timeout-ms = <50>;
            key-positions = <39 13 15>;
            bindings = <&sw_gui_prev>;
            slow-release;
        };

        combo_ctl_next {
            timeout-ms = <50>;
            key-positions = <39 14 16>;
            bindings = <&sw_ctl_next>;
            slow-release;
        };

        combo_ctl_prev {
            timeout-ms = <50>;
            key-positions = <39 14 15>;
            bindings = <&sw_ctl_prev>;
            slow-release;
        };

        combo_alt_next {
            timeout-ms = <50>;
            key-positions = <39 12 16>;
            bindings = <&sw_alt_next>;
            slow-release;
        };

        combo_alt_prev {
            timeout-ms = <50>;
            key-positions = <39 12 15>;
            bindings = <&sw_alt_prev>;
            slow-release;
        };
        
        
        
       
        combo_lbkt {
            timeout-ms = <30>;
            key-positions = <7 9>;
            bindings = <&kp LBKT>;
        };
        combo_rbkt {
            timeout-ms = <30>;
            key-positions = <7 10>;
            bindings = <&kp RBKT>;
        };

        combo_lpar {
            timeout-ms = <30>;
            key-positions = <19 21>;
            bindings = <&kp LPAR>;
        };
        combo_rpar {
            timeout-ms = <30>;
            key-positions = <19 22>;
            bindings = <&kp RPAR>;
        };
        
        combo_lbrc {
            timeout-ms = <30>;
            key-positions = <31 33>;
            bindings = <&kp LBRC>;
        };
        combo_rbrc {
            timeout-ms = <30>;
            key-positions = <31 34>;
            bindings = <&kp RBRC>;
        };

        combo_plus {
            timeout-ms = <30>;
            key-positions = <27 28>;
            bindings = <&kp PLUS>;
        };

        combo_minus {
            timeout-ms = <30>;
            key-positions = <26 27>;
            bindings = <&kp MINUS>;
        };

        combo_astrk {
            timeout-ms = <30>;
            key-positions = <14 15>;
            bindings = <&kp ASTRK>;
        };

        combo_equal {
            timeout-ms = <30>;
            key-positions = <42 31>;
            bindings = <&kp ASTRK>;
        };

        combo_under {
            timeout-ms = <30>;
            key-positions = <42 32>;
            bindings = <&kp UNDER>;
        };

        combo_colon {
            timeout-ms = <30>;
            key-positions = <42 34>;
            bindings = <&kp UNDER>;
        };

        // ==========================================
        // LEFT SYMBOLS (left thumb 39 + left keys)
        // ==========================================
        // Top row: `   |   &   ?   !   @
        combo_grave {
            timeout-ms = <50>;
            key-positions = <39 0>;
            bindings = <&kp GRAVE>;
        };
        combo_pipe {
            timeout-ms = <50>;
            key-positions = <39 1>;
            bindings = <&kp PIPE>;
        };
        combo_amps {
            timeout-ms = <50>;
            key-positions = <39 2>;
            bindings = <&kp AMPS>;
        };
        combo_qmark {
            timeout-ms = <50>;
            key-positions = <39 3>;
            bindings = <&kp QMARK>;
        };
        combo_excl {
            timeout-ms = <50>;
            key-positions = <39 4>;
            bindings = <&kp EXCL>;
        };
        combo_at {
            timeout-ms = <50>;
            key-positions = <39 5>;
            bindings = <&kp AT>;
        };

        // Home row positions 13-16 are reserved for left-hand modifier combos.
        combo_tilde {
            timeout-ms = <50>;
            key-positions = <39 12>;
            bindings = <&kp TILDE>;
        };
        // Bottom row: ;   '   <   [   ]   >
        combo_semi {
            timeout-ms = <50>;
            key-positions = <39 24>;
            bindings = <&kp SEMI>;
        };
        combo_sqt {
            timeout-ms = <50>;
            key-positions = <39 25>;
            bindings = <&kp SQT>;
        };
        combo_lt {
            timeout-ms = <50>;
            key-positions = <39 26>;
            bindings = <&kp LT>;
        };

        combo_gt {
            timeout-ms = <50>;
            key-positions = <39 29>;
            bindings = <&kp GT>;
        };
        // ==========================================
        // RIGHT SYMBOLS (right thumb 42 + right keys)
        // ==========================================
        // Top row: ^   #   *   $   BSLH
        combo_caret {
            timeout-ms = <50>;
            key-positions = <42 7>;
            bindings = <&kp CARET>;
        };
        combo_hash {
            timeout-ms = <50>;
            key-positions = <42 8>;
            bindings = <&kp HASH>;
        };
        combo_dllr {
            timeout-ms = <50>;
            key-positions = <42 10>;
            bindings = <&kp DLLR>;
        };
        combo_bslh {
            timeout-ms = <50>;
            key-positions = <42 11>;
            bindings = <&kp BSLH>;
        };

        // Home row positions 19-22 are reserved for right-hand modifier combos.
        combo_prcnt {
            timeout-ms = <50>;
            key-positions = <42 23>;
            bindings = <&kp PRCNT>;
        };

        // Bottom row: :   ;   /   ,   .
        combo_semi_r {
            timeout-ms = <50>;
            key-positions = <42 32>;
            bindings = <&kp SEMI>;
        };
        combo_fslh {
            timeout-ms = <50>;
            key-positions = <42 33>;
            bindings = <&kp FSLH>;
        };
        combo_comma {
            timeout-ms = <50>;
            key-positions = <42 34>;
            bindings = <&kp COMMA>;
        };
        combo_dot {
            timeout-ms = <50>;
            key-positions = <42 35>;
            bindings = <&kp DOT>;
        };
    };
};

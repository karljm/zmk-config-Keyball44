/ {
    combos {
        compatible = "zmk,combos";
        combo_to_base {
            timeout-ms = <50>;
            key-positions = <19 20 21>;
            bindings = <&to 0>;
        };

        combo_esc {
            timeout-ms = <25>;
            key-positions = <19 20>;
            bindings = <&kp ESCAPE>;
            layers = <0>;
        };

        // LETTERS
        combo_z {
            timeout-ms = <25>;
            key-positions = <3 4>;
            bindings = <&kp Z>;
            layers = <0>;
        };

        // MODIFIERS
        combo_lgui {
            timeout-ms = <50>;
            key-positions = <39 14>;
            bindings = <&skq LGUI>;
            slow-release;
        };

        combo_lsft {
            timeout-ms = <50>;
            key-positions = <39 16>;
            bindings = <&skq LEFT_SHIFT>;
            slow-release;
        };

        combo_lctl {
            timeout-ms = <50>;
            key-positions = <39 13>;
            bindings = <&skq LCTRL>;
            slow-release;
        };

        combo_lalt {
            timeout-ms = <50>;
            key-positions = <39 15>;
            bindings = <&skq LALT>;
            slow-release;
        };

        combo_lboot {
            timeout-ms = <500>;
            key-positions = <26 27 28 29 40>;
            bindings = <&bootloader>;
        };

        combo_rboot {
            timeout-ms = <500>;
            key-positions = <30 31 32 33 41>;
            bindings = <&bootloader>;
        };

        combo_rgui {
            timeout-ms = <50>;
            key-positions = <42 21>;
            bindings = <&skq RGUI>;
            slow-release;
        };

        combo_rsft {
            timeout-ms = <50>;
            key-positions = <42 19>;
            bindings = <&skq RIGHT_SHIFT>;
            slow-release;
        };

        combo_rctl {
            timeout-ms = <50>;
            key-positions = <42 22>;
            bindings = <&skq RCTRL>;
            slow-release;
        };

        combo_ralt {
            timeout-ms = <50>;
            key-positions = <42 20>;
            bindings = <&skq RALT>;
            slow-release;
        };

        // LAYERS
        combo_setting {
            timeout-ms = <50>;
            key-positions = <42 43>;
            bindings = <&mo SETTING>;
            layers = <0>;
        };

        combo_mouse {
            timeout-ms = <50>;
            key-positions = <38 28>;
            bindings = <&mo MOUSE>;
            layers = <0>;
            slow-release;
        };

        combo_scroll {
            timeout-ms = <50>;
            key-positions = <38 15>;
            bindings = <&tog_on SCROLL>;
            layers = <0>;
            slow-release;
        };

        combo_hscroll {
            timeout-ms = <50>;
            key-positions = <38 26>;
            bindings = <&tog_on HSCROLL>;
            layers = <0>;
            slow-release;
        };

        combo_snipe {
            timeout-ms = <50>;
            key-positions = <38 37>;
            bindings = <&mo SNIPE>;
            layers = <0>;
            slow-release;
        };

        // SWITCHING
        combo_gui_next {
            timeout-ms = <50>;
            key-positions = <14 16 39>;
            bindings = <&sw_gui_next>;
            layers = <0>;
            slow-release;
        };

        combo_ctl_next {
            timeout-ms = <50>;
            key-positions = <13 16 39>;
            bindings = <&sw_ctl_next>;
            layers = <0>;
            slow-release;
        };

        combo_alt_next {
            timeout-ms = <50>;
            key-positions = <26 28 39>;
            bindings = <&sw_alt_next>;
            layers = <0>;
            slow-release;
        };

        combo_alt_next_both {
            timeout-ms = <25>;
            key-positions = <32 28>;
            bindings = <&sw_alt_next>;
            layers = <0>;
            slow-release;
        };

        combo_alt_prev_both {
            timeout-ms = <25>;
            key-positions = <32 27>;
            bindings = <&sw_alt_prev>;
            layers = <0>;
            slow-release;
        };
        
        combo_ctl_next_both {
            timeout-ms = <25>;
            key-positions = <31 28>;
            bindings = <&sw_ctl_next>;
            layers = <0>;
            slow-release;
        };
        
        combo_ctl_prev_both {
            timeout-ms = <25>;
            key-positions = <31 27>;
            bindings = <&sw_ctl_prev>;
            layers = <0>;
            slow-release;
        };


        combo_gui_next_both {
            timeout-ms = <25>;
            key-positions = <33 28>;
            bindings = <&sw_gui_next>;
            layers = <0>;
            slow-release;
        };


        combo_gui_prev_both {
            timeout-ms = <25>;
            key-positions = <33 27>;
            bindings = <&sw_gui_prev>;
            layers = <0>;
            slow-release;
        };






        // NON-THUMB SYMBOLS 
        combo_backslash {
            timeout-ms = <30>;
            key-positions = <25 29>;
            bindings = <&kp BSLH>;
            layers = <0>;
        };
        combo_less_than {
            timeout-ms = <30>;
            key-positions = <26 27>;
            bindings = <&kp LT>;
            layers = <0>;
        };
        combo_greater_than {
            timeout-ms = <30>;
            key-positions = <27 28>;
            bindings = <&kp GT>;
            layers = <0>;
        };

        combo_lbkt {
            timeout-ms = <30>;
            key-positions = <7 9>;
            bindings = <&kp LBKT>;
            layers = <0>;
        };
        combo_rbkt {
            timeout-ms = <30>;
            key-positions = <7 10>;
            bindings = <&kp RBKT>;
            layers = <0>;
        };

        combo_lpar {
            timeout-ms = <30>;
            key-positions = <19 21>;
            bindings = <&kp LPAR>;
            layers = <0>;
        };
        combo_rpar {
            timeout-ms = <30>;
            key-positions = <19 22>;
            bindings = <&kp RPAR>;
            layers = <0>;
        };
        
        combo_lbrc {
            timeout-ms = <30>;
            key-positions = <31 33>;
            bindings = <&kp LBRC>;
            layers = <0>;
        };
        combo_rbrc {
            timeout-ms = <30>;
            key-positions = <31 34>;
            bindings = <&kp RBRC>;
            layers = <0>;
        };

        combo_sqt {
            timeout-ms = <30>;
            key-positions = <20 21>;
            bindings = <&kp SQT>;
            layers = <0>;
        };

        combo_dqt {
            timeout-ms = <30>;
            key-positions = <8 9>;
            bindings = <&kp DQT>;
            layers = <0>;
        };

        combo_caret {
            timeout-ms = <30>;
            key-positions = <31 32>;
            bindings = <&kp CARET>;
            layers = <0>;
        };
        combo_dollar {
            timeout-ms = <30>;
            key-positions = <32 33>;
            bindings = <&kp DLLR>;
            layers = <0>;
        };
        
        // THUMB SYMBOLS
        // LEFT
        
        combo_grave {
            timeout-ms = <30>;
            key-positions = <39 1>;
            bindings = <&kp GRAVE>;
            layers = <0>;
        };
        combo_tilde {
            timeout-ms = <30>;
            key-positions = <39 2>;
            bindings = <&kp TILDE>;
            layers = <0>;
        };
        
        combo_percent {
            timeout-ms = <25>;
            key-positions = <39 25>;
            bindings = <&kp PRCNT>;
            layers = <0>;
        };
        combo_astrk {
            timeout-ms = <30>;
            key-positions = <39 26>;
            bindings = <&kp ASTRK>;
            layers = <0>;
        };
        combo_minus {
            timeout-ms = <30>;
            key-positions = <39 27>;
            bindings = <&kp MINUS>;
            layers = <0>;
        };
        combo_plus {
            timeout-ms = <30>;
            key-positions = <39 28>;
            bindings = <&kp PLUS>;
            layers = <0>;
        };

        // RIGHT

        combo_ampersand {
            timeout-ms = <30>;
            key-positions = <42 7>;
            bindings = <&kp AMPS>;
            layers = <0>;
        };
        combo_pipe {
            timeout-ms = <30>;
            key-positions = <42 8>;
            bindings = <&kp PIPE>;
            layers = <0>;
        };
        combo_hash {
            timeout-ms = <30>;
            key-positions = <42 9>;
            bindings = <&kp HASH>;
            layers = <0>;
        };

        combo_equal {
            timeout-ms = <30>;
            key-positions = <42 31>;
            bindings = <&kp EQUAL>;
            layers = <0>;
        };
        combo_under {
            timeout-ms = <30>;
            key-positions = <42 33>;
            bindings = <&kp UNDER>;
            layers = <0>;
        };
        combo_colon {
            timeout-ms = <30>;
            key-positions = <42 33>;
            bindings = <&kp COLON>;
            layers = <0>;
        };
        combo_at {
            timeout-ms = <30>;
            key-positions = <42 34>;
            bindings = <&kp AT>;
            layers = <0>;
        };
    };
};
